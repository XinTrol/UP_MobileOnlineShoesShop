<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Белый круг (подложка) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF"/>
            <!-- Размер можно не указывать, он подстроится под иконку,
                 но padding поможет сделать круг больше иконки -->
            <size android:width="108dp" android:height="108dp"/>
        </shape>
    </item>

    <!-- Сама иконка (стандартная заглушка) -->
    <item
        android:width="60dp"
        android:height="60dp"
        android:gravity="center">
        <!-- Я использую стандартную иконку человека, вы можете заменить на свою -->
        <vector
            android:width="60dp"
            android:height="60dp"
            android:viewportWidth="24"
            android:viewportHeight="24"
            android:tint="#000000"> <!-- Цвет иконки, например черный -->
            <path
                android:fillColor="@android:color/white"
                android:pathData="M12,12c2.21,0 4,-1.79 4,-4s-1.79,-4 -4,-4 -4,1.79 -4,4 1.79,4 4,4zM12,14c-2.67,0 -8,1.34 -8,4v2h16v-2c0,-2.66 -5.33,-4 -8,-4z"/>
        </vector>
    </item>
</layer-list>